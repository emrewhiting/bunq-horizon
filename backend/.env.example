# Backend environment variables — copy to .env and fill in.

# Anthropic — for Claude Sonnet vision classification.
# Get one at https://console.anthropic.com.
ANTHROPIC_API_KEY=
# Default model. Bump if a newer Sonnet drops.
ANTHROPIC_MODEL=claude-sonnet-4-6

# bunq sandbox — only needed if you want live transaction data.
# Without this, /balance returns a cached snapshot from bunq_data.json.
BUNQ_API_KEY=sandbox_3491eee3bb5cfa3c022a5332db7e28e95833b22fa55a119f2d186199

# Server port (Render/Railway override this automatically)
PORT=8000
